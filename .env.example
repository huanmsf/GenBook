# GenBook OCR 配置模板
# 复制此文件为 .env，填入真实凭证（.env 不会提交到 git）

# ── OCR 后端选择 ──────────────────────────────────────────
# 可选值: baidu | tencent | google（默认: baidu）
OCR_BACKEND=baidu

# ── 百度智能云 OCR ────────────────────────────────────────
# 申请地址: https://cloud.baidu.com/product/ocr_general
BAIDU_OCR_APP_ID=你的AppID
BAIDU_OCR_API_KEY=你的APIKey
BAIDU_OCR_SECRET_KEY=你的SecretKey

# ── 腾讯云 OCR ────────────────────────────────────────────
# 申请地址: https://cloud.tencent.com/product/ocr
# TENCENT_SECRET_ID=你的SecretId
# TENCENT_SECRET_KEY=你的SecretKey
# TENCENT_REGION=ap-guangzhou

# ── Google Cloud Vision ───────────────────────────────────
# 申请地址: https://cloud.google.com/vision
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
